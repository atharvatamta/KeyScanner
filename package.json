{
  "name": "keyscanner",
  "version": "1.0.0",
  "description": "A security-research CLI that scans website frontend JavaScript and public source for accidentally exposed API keys, so they can be reported and remediated.",
  "type": "module",
  "bin": {
    "keyscanner": "./src/index.js"
  },
  "scripts": {
    "start": "node ./src/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "security",
    "secret-scanning",
    "api-keys",
    "responsible-disclosure",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "cheerio": "^1.0.0",
    "commander": "^12.1.0",
    "js-beautify": "^1.15.1",
    "node-fetch": "^3.3.2",
    "ora": "^8.1.0",
    "p-limit": "^6.1.0"
  }
}
